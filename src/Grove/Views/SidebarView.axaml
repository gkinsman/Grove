<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Grove.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="280" d:DesignHeight="700"
             x:Class="Grove.Views.SidebarView"
             x:DataType="vm:MainWindowViewModel"
             Name="Root">

    <Border Background="{DynamicResource SidebarBackgroundBrush}">
        <DockPanel>
            <!-- Header -->
            <StackPanel DockPanel.Dock="Top" Margin="16,12"
                        Orientation="Horizontal" Spacing="10">
                <Image Source="/Assets/grove-logo-32.png"
                       Width="24" Height="24"
                       VerticalAlignment="Center" />
                <TextBlock Text="grove"
                           FontSize="18"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource SidebarForegroundBrush}" />
            </StackPanel>

            <!-- Bottom buttons -->
            <StackPanel DockPanel.Dock="Bottom" Margin="8,8">
                <Button Content="+ add root"
                        Command="{Binding AddRootCommand}"
                        Classes="sidebar-action" />
            </StackPanel>

            <!-- Root groups -->
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Roots}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="vm:RootViewModel">
                            <StackPanel Margin="0,2">
                                <!-- Root header -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Button Grid.Column="0"
                                            Command="{Binding ToggleExpandCommand}"
                                            Classes="root-header"
                                            HorizontalContentAlignment="Left">
                                        <TextBlock Text="{Binding Name}"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SidebarGroupHeaderBrush}" />
                                    </Button>
                                    <Button Grid.Column="1"
                                            Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).RemoveRootCommand}"
                                            CommandParameter="{Binding}"
                                            Classes="root-remove"
                                            ToolTip.Tip="Remove root">
                                        <TextBlock Text="✕"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource SidebarGroupHeaderBrush}" />
                                    </Button>
                                </Grid>

                                <!-- Worktree entries -->
                                <ItemsControl ItemsSource="{Binding Worktrees}"
                                              IsVisible="{Binding IsExpanded}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="vm:WorktreeViewModel">
                                            <Button Classes="worktree-entry"
                                                    Command="{Binding #Root.((vm:MainWindowViewModel)DataContext).SelectWorktreeCommand}"
                                                    CommandParameter="{Binding}">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Ellipse Width="8" Height="8"
                                                             Fill="{Binding StatusColor}"
                                                             VerticalAlignment="Center" />
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding BranchName}"
                                                                   FontWeight="Medium"
                                                                   Foreground="{DynamicResource SidebarForegroundBrush}" />
                                                        <TextBlock Text="{Binding ShortPath}"
                                                                   FontSize="11"
                                                                   Opacity="0.6"
                                                                   Foreground="{DynamicResource SidebarForegroundBrush}" />
                                                    </StackPanel>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </DockPanel>
    </Border>

</UserControl>
