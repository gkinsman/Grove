<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Grove.ViewModels"
             xmlns:views="using:Grove.Views"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="700"
             x:Class="Grove.Views.WorktreeDetailView"
             x:DataType="vm:WorktreeDetailViewModel">

    <DockPanel Background="{DynamicResource DetailBackgroundBrush}">

        <!-- Header -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource DetailHeaderBackgroundBrush}"
                Padding="24,16"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Spacing="4">
                    <TextBlock Text="{Binding BranchName}"
                               FontSize="22"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SidebarForegroundBrush}" />
                    <StackPanel Orientation="Horizontal" Spacing="8" Opacity="0.6">
                        <TextBlock Text="{Binding FullPath}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SidebarForegroundBrush}" />
                        <TextBlock Text="·"
                                   FontSize="12"
                                   Foreground="{DynamicResource SidebarForegroundBrush}"
                                   IsVisible="{Binding UpstreamBranch, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                        <TextBlock Text="{Binding UpstreamBranch}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SidebarForegroundBrush}"
                                   IsVisible="{Binding UpstreamBranch, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </StackPanel>

                <!-- Status badge -->
                <Border Grid.Column="1"
                        Classes="status-badge"
                        Classes.running="{Binding IsRunning}"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding StatusText}"
                                   FontSize="12"
                                   Foreground="{DynamicResource SidebarForegroundBrush}" />
                        <TextBlock Text="{Binding Elapsed}"
                                   FontSize="12"
                                   Opacity="0.6"
                                   Foreground="{DynamicResource SidebarForegroundBrush}"
                                   IsVisible="{Binding Elapsed, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Command bar -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource CommandBarBackgroundBrush}"
                Padding="24,12"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="10">
                <TextBlock Text="COMMAND"
                           Classes="section-label"
                           Foreground="{DynamicResource SidebarForegroundBrush}" />

                <!-- Command input + buttons -->
                <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                    <TextBox Text="{Binding Command}"
                             FontFamily="Cascadia Code,Cascadia Mono,Consolas,monospace"
                             FontSize="13"
                             Watermark="Enter command..."
                             VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            Content="Run"
                            Command="{Binding RunCommand}"
                            Margin="8,0,0,0"
                            Background="{DynamicResource AccentGreenBrush}"
                            Foreground="#11111B"
                            FontWeight="SemiBold" />
                    <Button Grid.Column="2"
                            Content="Stop"
                            Command="{Binding StopCommand}"
                            Margin="8,0,0,0" />
                    <Button Grid.Column="3"
                            Content="Restart"
                            Command="{Binding RestartCommand}"
                            Margin="8,0,0,0" />
                </Grid>

                <!-- Preset chips -->
                <ItemsControl ItemsSource="{Binding Presets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Button Content="{Binding Name}"
                                    Classes="preset-chip"
                                    Command="{Binding $parent[UserControl].((vm:WorktreeDetailViewModel)DataContext).LoadPresetCommand}"
                                    CommandParameter="{Binding}" />
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </Border>

        <!-- Console output -->
        <views:ConsoleView />

    </DockPanel>

</UserControl>
