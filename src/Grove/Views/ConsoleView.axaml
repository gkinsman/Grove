<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:Grove.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="400"
             x:Class="Grove.Views.ConsoleView"
             x:DataType="vm:WorktreeDetailViewModel">

    <Border Background="{DynamicResource ConsoleBackgroundBrush}">
        <DockPanel>
            <!-- Console toolbar -->
            <Border DockPanel.Dock="Top"
                    Padding="16,6"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <TextBlock Text="CONSOLE"
                               Classes="section-label"
                               Foreground="{DynamicResource ConsoleForegroundBrush}"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal"
                                Spacing="8"
                                VerticalAlignment="Center">
                        <Button Content="Clear"
                                Command="{Binding ClearConsoleCommand}"
                                Classes="preset-chip" />
                        <Button Content="Copy"
                                Name="CopyButton"
                                Classes="preset-chip" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Console output — single selectable text block for cross-line selection -->
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Name="ConsoleScroller">
                <SelectableTextBlock Classes="console-line"
                                     Name="ConsoleTextBlock"
                                     Margin="16,0"
                                     Padding="0,4,0,24" />
            </ScrollViewer>
        </DockPanel>
    </Border>

</UserControl>
